# Template_Filler - Configuração de Ambiente

# Google Cloud Service Account
GOOGLE_APPLICATION_CREDENTIALS="/path/to/your/credentials.json"
TEMPLATE_FILLER_DRIVE_FOLDER_ID="your_google_drive_folder_id"

# Logging e Debug
TEMPLATE_FILLER_LOG_LEVEL="INFO"
TEMPLATE_FILLER_DEBUG="false"

# Rate limiting Google API  
TEMPLATE_FILLER_MAX_REQUESTS_PER_MINUTE="60"
TEMPLATE_FILLER_RETRY_ATTEMPTS="3"

# MCP Server (se usar)
TEMPLATE_FILLER_MCP_PORT="8080"
TEMPLATE_FILLER_MCP_HOST="localhost"

# Desenvolvimento
TEMPLATE_FILLER_ENV="development"