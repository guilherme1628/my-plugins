# Template_Filler — Environment Configuration

# Base data directory (templates, contratada JSONs, generated docs)
# Default: ~/Documents/template_filler_data
TEMPLATE_FILLER_DIR="$HOME/Documents/template_filler_data"

# Logging
TEMPLATE_FILLER_LOG_LEVEL="INFO"
TEMPLATE_FILLER_DEBUG="false"

# ReceitaWS rate limit
TEMPLATE_FILLER_MAX_REQUESTS_PER_MINUTE="60"
TEMPLATE_FILLER_RETRY_ATTEMPTS="3"

# Environment
TEMPLATE_FILLER_ENV="development"
