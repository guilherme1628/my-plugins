{
  "description": "Convex development validation hooks",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-commit-checks.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
